# Site Configuration
SITE_URL=http://localhost:4321
SITE_NAME=Public Code US
SITE_DESCRIPTION=Demand publicly funded software to be publicly owned and transparent. Sign the petition for public code in America.

# Build Environment
# Options: development, production
NODE_ENV=development

# AWS Configuration (optional for deployment)
