---
import Layout from '../layouts/main.astro';
---

<Layout
	title="Resources - Public Code Downloads & References"
	description="Downloadable materials, guides, social media toolkit, and links to organizations working on public code advocacy."
	currentPage="/resources"
>
	{/* Hero */}
	<section class="bg-am-dark text-am-light border-b-4 border-am-dark py-20">
		<div class="max-w-4xl mx-auto px-4">
			<h1 class="text-5xl md:text-6xl font-bold mb-6">Resources</h1>
			<p class="text-lg font-bold">
				Materials to help you understand, advocate for, and share public code.
			</p>
		</div>
	</section>

	{/* Downloadables */}
	<section class="bg-am-light border-b-4 border-am-dark py-20">
		<div class="max-w-4xl mx-auto px-4">
			<h2 class="text-4xl font-bold text-am-dark mb-12">Download Materials</h2>
			<div class="grid md:grid-cols-2 gap-6">
				{/* One-Pager */}
				<div class="card-am bg-am-white">
					<h3 class="text-xl font-bold text-am-dark mb-3">One-Page Guide</h3>
					<p class="font-bold text-am-dark mb-6">
						Quick overview of why public code matters. Perfect for sharing with friends and policymakers.
					</p>
					<a href="/downloads/public-code-one-pager.pdf" download class="btn-am inline-block">
						📥 Download PDF
					</a>
				</div>

				{/* Deep Dive */}
				<div class="card-am bg-am-red text-am-dark">
					<h3 class="text-xl font-bold mb-3">Complete Guide</h3>
					<p class="font-bold mb-6">
						In-depth explanation: history, benefits, case studies, and implementation strategies.
					</p>
					<a href="/downloads/public-code-complete-guide.pdf" download class="btn-am">
						📥 Download PDF
					</a>
				</div>

				{/* Cost Analysis */}
				<div class="card-am bg-am-light-blue text-am-dark">
					<h3 class="text-xl font-bold mb-3">Cost Savings Analysis</h3>
					<p class="font-bold mb-6">
						Data-driven breakdown of how much taxpayers waste on duplicated proprietary software.
					</p>
					<a href="/downloads/cost-savings-analysis.pdf" download class="btn-am">
						📥 Download PDF
					</a>
				</div>

				{/* FAQ */}
				<div class="card-am bg-am-blue">
					<h3 class="text-xl font-bold text-am-dark mb-3">FAQ Document</h3>
					<p class="font-bold text-am-dark mb-6">
						Answers to common questions about public code, open source, and ballot initiatives.
					</p>
					<a href="/downloads/faq.pdf" download class="btn-am">
						📥 Download PDF
					</a>
				</div>

				{/* State Guide */}
				<div class="card-am bg-am-light border-4 border-am-dark">
					<h3 class="text-xl font-bold text-am-dark mb-3">State Ballot Guide</h3>
					<p class="font-bold text-am-dark mb-6">
						How to qualify for ballot initiatives in your state. Laws vary—find your state's requirements.
					</p>
					<a href="/downloads/state-ballot-guide.pdf" download class="btn-am">
						📥 Download PDF
					</a>
				</div>

				{/* Presentation */}
				<div class="card-am bg-am-light border-4 border-am-dark">
					<h3 class="text-xl font-bold text-am-dark mb-3">Presentation Deck</h3>
					<p class="font-bold text-am-dark mb-6">
						PowerPoint/Google Slides you can use for community presentations and education.
					</p>
					<a href="/downloads/presentation.pptx" download class="btn-am">
						📥 Download PPTX
					</a>
				</div>
			</div>
		</div>
	</section>

	{/* Social Toolkit */}
	<section class="bg-am-blue border-b-4 border-am-dark py-20">
		<div class="max-w-6xl mx-auto px-4">
			<h2 class="text-4xl font-bold text-am-dark mb-4">Social Media Toolkit</h2>
			<p class="text-lg font-bold text-am-dark mb-12">
				Pick your favorite design, download, and share. All images are free to use under CC-BY-SA.
				Scroll each row to see all options.
			</p>

			{/* 1:1 Square */}
			<div class="mb-12">
				<h3 class="text-2xl font-bold text-am-dark mb-2">1:1 Square <span class="text-sm font-bold text-am-dark opacity-60">— Instagram / Facebook post</span></h3>
				<div class="flex gap-4 overflow-x-auto pb-4" style="scrollbar-width: thin;">
					{[
						{ file: "social-1a.png", label: "Option A — Dark" },
						{ file: "social-1b.png", label: "Option B — White" },
						{ file: "social-1c.png", label: "Option C — Blue" },
					].map(({ file, label }) => (
						<div class="flex-none w-72 border-4 border-am-dark bg-am-light p-3">
							<img src={`/downloads/${file}`} alt={label} class="w-full mb-3 block" loading="lazy" />
							<p class="font-bold text-am-dark text-sm mb-2">{label}</p>
							<a href={`/downloads/${file}`} download class="btn-am w-full text-center block text-sm">
								📥 Download
							</a>
						</div>
					))}
				</div>
			</div>

			{/* 16:9 Banner */}
			<div class="mb-12">
				<h3 class="text-2xl font-bold text-am-dark mb-2">16:9 Banner <span class="text-sm font-bold text-am-dark opacity-60">— Twitter/X header / Facebook cover</span></h3>
				<div class="flex gap-4 overflow-x-auto pb-4" style="scrollbar-width: thin;">
					{[
						{ file: "social-2a.png", label: "Option A — Split" },
						{ file: "social-2b.png", label: "Option B — Centered" },
						{ file: "social-2c.png", label: "Option C — Stat" },
					].map(({ file, label }) => (
						<div class="flex-none w-96 border-4 border-am-dark bg-am-light p-3">
							<img src={`/downloads/${file}`} alt={label} class="w-full mb-3 block" loading="lazy" />
							<p class="font-bold text-am-dark text-sm mb-2">{label}</p>
							<a href={`/downloads/${file}`} download class="btn-am w-full text-center block text-sm">
								📥 Download
							</a>
						</div>
					))}
				</div>
			</div>

			{/* Quote */}
			<div class="mb-12">
				<h3 class="text-2xl font-bold text-am-dark mb-2">Quote Cards <span class="text-sm font-bold text-am-dark opacity-60">— shareable quote images</span></h3>
				<div class="flex gap-4 overflow-x-auto pb-4" style="scrollbar-width: thin;">
					{[
						{ file: "social-3a.png", label: "Option A — Dark" },
						{ file: "social-3b.png", label: "Option B — Red" },
						{ file: "social-3c.png", label: "Option C — Light" },
					].map(({ file, label }) => (
						<div class="flex-none w-72 border-4 border-am-dark bg-am-light p-3">
							<img src={`/downloads/${file}`} alt={label} class="w-full mb-3 block" loading="lazy" />
							<p class="font-bold text-am-dark text-sm mb-2">{label}</p>
							<a href={`/downloads/${file}`} download class="btn-am w-full text-center block text-sm">
								📥 Download
							</a>
						</div>
					))}
				</div>
			</div>

			{/* CTA */}
			<div class="mb-4">
				<h3 class="text-2xl font-bold text-am-dark mb-2">Call to Action <span class="text-sm font-bold text-am-dark opacity-60">— petition drive graphics</span></h3>
				<div class="flex gap-4 overflow-x-auto pb-4" style="scrollbar-width: thin;">
					{[
						{ file: "social-4a.png", label: "Option A — Dark" },
						{ file: "social-4b.png", label: "Option B — White" },
						{ file: "social-4c.png", label: "Option C — Blue" },
					].map(({ file, label }) => (
						<div class="flex-none w-72 border-4 border-am-dark bg-am-light p-3">
							<img src={`/downloads/${file}`} alt={label} class="w-full mb-3 block" loading="lazy" />
							<p class="font-bold text-am-dark text-sm mb-2">{label}</p>
							<a href={`/downloads/${file}`} download class="btn-am w-full text-center block text-sm">
								📥 Download
							</a>
						</div>
					))}
				</div>
			</div>
		</div>
	</section>

	{/* External Resources */}
	<section class="bg-am-light border-b-4 border-am-dark py-20">
		<div class="max-w-4xl mx-auto px-4">
			<h2 class="text-4xl font-bold text-am-dark mb-12">Learn More</h2>
			<div class="space-y-4">
				<a href="https://publiccode.eu" target="_blank" rel="noopener noreferrer"
					class="border-4 border-am-dark p-6 block hover:shadow-am-lg bg-am-white transition-all">
					<h3 class="font-bold text-am-dark text-lg mb-2">Public Money, Public Code (EU)<span class="sr-only"> (opens in new tab)</span></h3>
					<p class="font-bold text-am-dark text-sm">The original campaign in Europe with 200+ organizations</p>
				</a>

				<a href="https://fsfe.org/activities/publiccode/" target="_blank" rel="noopener noreferrer"
					class="border-4 border-am-dark p-6 block hover:shadow-am-lg bg-am-red text-am-dark transition-all">
					<h3 class="font-bold text-lg mb-2">FSFE Public Code Initiative<span class="sr-only"> (opens in new tab)</span></h3>
					<p class="font-bold text-sm">Free Software Foundation Europe advocacy and resources</p>
				</a>

				<a href="https://standard.publiccode.net" target="_blank" rel="noopener noreferrer"
					class="border-4 border-am-dark p-6 block hover:shadow-am-lg bg-am-light-blue text-am-dark transition-all">
					<h3 class="font-bold text-lg mb-2">Public Code Standard<span class="sr-only"> (opens in new tab)</span></h3>
					<p class="font-bold text-sm">Official standard for public code implementation</p>
				</a>

				<a href="https://www.linuxfoundation.org" target="_blank" rel="noopener noreferrer"
					class="border-4 border-am-dark p-6 block hover:shadow-am-lg bg-am-blue transition-all">
					<h3 class="font-bold text-am-dark text-lg mb-2">Linux Foundation<span class="sr-only"> (opens in new tab)</span></h3>
					<p class="font-bold text-am-dark text-sm">Research on open source economic value and impact</p>
				</a>

				<a href="https://www.eff.org" target="_blank" rel="noopener noreferrer"
					class="border-4 border-am-dark p-6 block hover:shadow-am-lg bg-am-light text-am-dark transition-all">
					<h3 class="font-bold text-lg mb-2">Electronic Frontier Foundation<span class="sr-only"> (opens in new tab)</span></h3>
					<p class="font-bold text-sm">Digital rights and open source advocacy</p>
				</a>
			</div>
		</div>
	</section>

	{/* Cross-links */}
	<section class="bg-am-dark text-am-light border-b-4 border-am-dark py-16">
		<div class="max-w-4xl mx-auto px-4">
			<h2 class="text-3xl font-bold mb-8">Keep Going</h2>
			<div class="grid md:grid-cols-3 gap-4">
				<a href="/learn" class="border-4 border-am-light p-5 block hover:bg-am-blue hover:border-am-blue transition-all">
					<h3 class="font-bold text-lg mb-2">📖 Learn More</h3>
					<p class="font-bold opacity-80 text-sm">Deep dive into what public code is, how ballot initiatives work, and the case for change.</p>
				</a>
				<a href="/campaign" class="border-4 border-am-light p-5 block hover:bg-am-blue hover:border-am-blue transition-all">
					<h3 class="font-bold text-lg mb-2">🗺️ Campaign Map</h3>
					<p class="font-bold opacity-80 text-sm">See where we're active, find your state, and contact your representatives directly.</p>
				</a>
				<a href="/blog" class="border-4 border-am-light p-5 block hover:bg-am-blue hover:border-am-blue transition-all">
					<h3 class="font-bold text-lg mb-2">📰 Blog</h3>
					<p class="font-bold opacity-80 text-sm">Campaign updates, movement stories, and guides from the Public Code US team.</p>
				</a>
			</div>
		</div>
	</section>

	{/* CTA */}
	<section class="bg-am-light-blue text-am-dark border-b-4 border-am-dark py-16">
		<div class="max-w-4xl mx-auto px-4 text-center">
			<h2 class="text-3xl md:text-4xl font-bold mb-6">Ready to Make a Difference?</h2>
			<a href="/sign" class="btn-am btn-am-white inline-block">
				Sign the Petition Today
			</a>
		</div>
	</section>
</Layout>
