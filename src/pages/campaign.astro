---
import Layout from '../layouts/main.astro';
import { StateMapGrid } from '../components/StateMapGrid';
import { NewsletterSignup } from '../components/NewsletterSignup';
import { STATES, getActiveStates, getComingSoonStates, getBallotInitiativeStates } from '../lib/states';

const activeCount = getActiveStates().length;
const comingSoonCount = getComingSoonStates().length;
const ballotInitiativeCount = getBallotInitiativeStates().length;
const needOrganizerCount = ballotInitiativeCount - activeCount - comingSoonCount;
---

<Layout
  title="Campaign Status - Public Code US"
  description="Interactive map showing public code ballot initiative status in every state. See which states are actively organizing."
  currentPage="/campaign"
>
  {/* Hero */}
  <section class="bg-am-dark text-am-light border-b-4 border-am-dark py-20">
    <div class="max-w-4xl mx-auto px-4">
      <h1 class="text-6xl md:text-7xl font-bold mb-6">Campaign Map</h1>
      <p class="text-lg font-bold">
        See which states are actively campaigning for public code, and how you can get involved.
      </p>
    </div>
  </section>

  {/* Map Section */}
  <section class="bg-am-light border-b-4 border-am-dark py-20">
    <div class="max-w-6xl mx-auto px-4">
      <StateMapGrid client:load />
    </div>
  </section>

  {/* State Stats */}
  <section class="bg-am-blue border-b-4 border-am-dark py-20">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-4xl font-bold text-am-dark mb-12">Campaign Status</h2>

      <div class="grid md:grid-cols-3 gap-6 mb-12">
        <div class="card-am bg-am-red text-am-dark">
          <p class="text-sm font-bold uppercase tracking-widest mb-2">Active Campaigns</p>
          <p class="text-5xl font-bold">{activeCount}</p>
          <p class="font-bold mt-2">States currently organizing</p>
        </div>

        <div class="card-am bg-am-light-blue text-am-dark">
          <p class="text-sm font-bold uppercase tracking-widest mb-2">Coming Soon</p>
          <p class="text-5xl font-bold">{comingSoonCount}</p>
          <p class="font-bold mt-2">States preparing to launch</p>
        </div>

        <div class="card-am bg-am-white text-am-dark">
          <p class="text-sm font-bold uppercase tracking-widest mb-2">Ballot Initiative States</p>
          <p class="text-5xl font-bold">{ballotInitiativeCount}</p>
          <p class="font-bold mt-2">{needOrganizerCount} still need organizers</p>
        </div>
      </div>

      <div class="border-4 border-am-dark bg-am-light p-8">
        <h3 class="text-2xl font-bold text-am-dark mb-4">How Campaign Status Works</h3>
        <div class="space-y-4 font-bold text-am-dark">
          <div>
            <p class="text-am-red font-bold mb-2">🚀 Active Campaign</p>
            <p>We're collecting signatures and organizing. Visit the state page to sign and get involved.</p>
          </div>
          <div>
            <p class="text-am-light-blue font-bold mb-2">⏰ Coming Soon</p>
            <p>We're preparing for launch. Subscribe to our newsletter for the start date.</p>
          </div>
          <div>
            <p class="font-bold mb-2">❓ Need Organizer</p>
            <p>No campaign yet. Interested in leading the effort? Contact <a href="mailto:organize@publiccode.us" class="underline">organize@publiccode.us</a></p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Newsletter CTA */}
  <section class="bg-am-red text-am-light border-b-4 border-am-dark py-20">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-3xl md:text-4xl font-bold mb-8 text-center">
        Get Campaign Updates
      </h2>
      <div class="max-w-md mx-auto">
        <NewsletterSignup
          client:load
          variant="card"
          source="campaign"
        />
      </div>
    </div>
  </section>

  {/* Next Steps */}
  <section class="bg-am-light border-b-4 border-am-dark py-20">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-4xl font-bold text-am-dark mb-12">How to Help</h2>

      <div class="grid md:grid-cols-2 gap-6">
        <a href="/sign" class="card-am bg-am-white hover:shadow-am-lg transition-all cursor-pointer">
          <h3 class="text-2xl font-bold text-am-dark mb-4">Sign the Petition</h3>
          <p class="font-bold text-am-dark mb-4">
            Add your signature to show support for public code in America.
          </p>
          <p class="text-am-red font-bold">Start Here →</p>
        </a>

        <a href="/organize" class="card-am bg-am-light-blue text-am-dark hover:shadow-am-lg transition-all cursor-pointer">
          <h3 class="text-2xl font-bold mb-4">Get Organizing Guide</h3>
          <p class="font-bold mb-4">
            Learn how to collect signatures and build a campaign in your state.
          </p>
          <p class="text-am-dark font-bold">Learn More →</p>
        </a>

        <a href="mailto:organize@publiccode.us" class="card-am bg-am-dark text-am-light hover:shadow-am-lg transition-all cursor-pointer">
          <h3 class="text-2xl font-bold mb-4">Lead a State Campaign</h3>
          <p class="font-bold mb-4">
            Interested in organizing in your state? We need leaders.
          </p>
          <p class="text-am-light font-bold">Express Interest →</p>
        </a>

        <a href="/blog" class="card-am bg-am-blue hover:shadow-am-lg transition-all cursor-pointer">
          <h3 class="text-2xl font-bold text-am-dark mb-4">Read Our Blog</h3>
          <p class="font-bold text-am-dark mb-4">
            Campaign updates, organizing tips, and public code insights.
          </p>
          <p class="text-am-dark font-bold">Read Posts →</p>
        </a>
      </div>
    </div>
  </section>
</Layout>
