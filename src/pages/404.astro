---
import Layout from '../layouts/main.astro';
---

<Layout
  title="404 - Page Not Found"
  description="The page you're looking for doesn't exist."
>
  <section class="bg-am-light border-b-4 border-am-dark">
    <div class="flex items-center justify-center min-h-[60vh]">
      <div class="text-center space-y-6 max-w-md px-4">
        <h1 class="text-9xl font-bold text-am-red">404</h1>
        <h2 class="text-3xl font-bold text-am-dark">Page Not Found</h2>
        <p class="font-bold text-am-dark">
          The page you're looking for doesn't exist. It might have been moved or deleted.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="/" class="btn-am btn-am-primary inline-block text-center">
            Go Home
          </a>
          <button onclick="history.back()" class="btn-am inline-block text-center">
            Go Back
          </button>
        </div>
      </div>
    </div>
  </section>
</Layout>
