---
import Layout from '../layouts/main.astro';
import { PetitionForm } from '../components/PetitionForm';
---

<Layout
	title="Sign the Public Code Petition - Add Your Voice"
	description="Sign the petition for public code and transparency in US government. Join thousands of supporters demanding openly available government software."
	currentPage="/sign"
>
	{/* Hero */}
	<section class="bg-am-red text-am-light border-b-4 border-am-dark py-20">
		<div class="max-w-4xl mx-auto px-4">
			<h1 class="text-5xl md:text-6xl font-bold mb-6">Sign the Petition</h1>
			<p class="text-lg font-bold">
				Add your signature to demand that public software be publicly owned. Your voice matters.
			</p>
		</div>
	</section>

	{/* Signature Count */}
	<section class="bg-am-white border-b-4 border-am-dark py-12">
		<div class="max-w-4xl mx-auto px-4 text-center">
			<p class="text-sm font-bold uppercase tracking-widest text-am-dark mb-2">Current Signatures</p>
			<p class="text-6xl md:text-7xl font-bold text-am-dark">2,847</p>
			<p class="font-bold text-am-dark mt-4">And counting. Join them.</p>
		</div>
	</section>

	{/* Form Section */}
	<section class="bg-am-light border-b-4 border-am-dark py-20">
		<div class="max-w-4xl mx-auto">
			<div class="grid md:grid-cols-3 gap-8 px-4 md:px-0">
				{/* Left Column - Info */}
				<div class="md:col-span-1">
					<h2 class="text-2xl font-bold text-am-dark mb-6">What Happens Next?</h2>
					<div class="space-y-6">
						<div>
							<p class="text-3xl font-bold text-am-red mb-2">1</p>
							<h3 class="font-bold text-am-dark mb-2">We Gather Signatures</h3>
							<p class="font-bold text-sm text-am-dark">
								We're collecting signatures from voters across the country.
							</p>
						</div>
						<div>
							<p class="text-3xl font-bold text-am-light-blue mb-2">2</p>
							<h3 class="font-bold text-am-dark mb-2">We Build Momentum</h3>
							<p class="font-bold text-sm text-am-dark">
								Your signature shows policymakers there's real demand for change.
							</p>
						</div>
						<div>
							<p class="text-3xl font-bold text-am-white mb-2">3</p>
							<h3 class="font-bold text-am-dark mb-2">We Get to the Ballot</h3>
							<p class="font-bold text-sm text-am-dark">
								Once we have enough signatures, we qualify for the ballot in targeted states.
							</p>
						</div>
						<div>
							<p class="text-3xl font-bold text-am-red mb-2">4</p>
							<h3 class="font-bold text-am-dark mb-2">We Win Public Code</h3>
							<p class="font-bold text-sm text-am-dark">
								Voters pass the measure. Public code becomes law.
							</p>
						</div>
					</div>
				</div>

				{/* Right Column - Form */}
				<div class="md:col-span-2">
					<div class="border-4 border-am-dark bg-am-blue p-8">
						<PetitionForm client:load />
					</div>
				</div>
			</div>
		</div>
	</section>

	{/* Social Share Section */}
	<section class="bg-am-light-blue text-am-light border-b-4 border-am-dark py-20">
		<div class="max-w-4xl mx-auto px-4 text-center">
			<h2 class="text-4xl font-bold mb-8">Spread the Word</h2>
			<p class="text-lg font-bold mb-8">
				Know someone who cares about government transparency? Share this petition.
			</p>
			<div class="flex flex-wrap justify-center gap-4">
				<a href="https://www.threads.net/intent/post?text=I%20just%20signed%20the%20petition%20for%20public%20code%20in%20America.%20Public%20money%20should%20fund%20public%20software.%20Join%20me:%20publiccode.us" target="_blank" rel="noopener noreferrer"
					class="btn-am btn-am-white">
					Share on Threads
				</a>
				<a href="https://www.facebook.com/sharer/sharer.php?u=https://publiccode.us/sign" target="_blank" rel="noopener noreferrer"
					class="btn-am btn-am-white">
					Share on Facebook
				</a>
				<a href="mailto:?subject=Sign%20the%20Public%20Code%20Petition&body=Public%20money%20should%20fund%20public%20code.%20Sign%20the%20petition%3A%20https%3A%2F%2Fpubliccode.us%2Fsign"
					class="btn-am btn-am-white">
					Share via Email
				</a>
			</div>
		</div>
	</section>

	{/* FAQ */}
	<section class="bg-am-light border-b-4 border-am-dark py-20">
		<div class="max-w-4xl mx-auto px-4">
			<h2 class="text-4xl font-bold text-am-dark mb-12">Petition FAQ</h2>
			<div class="space-y-4">
				<details class="border-4 border-am-dark p-6 cursor-pointer bg-am-blue group">
					<summary class="font-bold text-am-dark text-lg flex justify-between items-center">
						<span>Is my information secure?</span>
						<span class="group-open:rotate-45 transition-transform text-2xl leading-none" aria-hidden="true">+</span>
					</summary>
					<p class="font-bold text-am-dark mt-4">
						Yes. We use industry-standard security (HTTPS encryption). We'll never sell your data. We only use your information to update you about the campaign (if you opt in) and to verify signatures for ballot qualification.
					</p>
				</details>

				<details class="border-4 border-am-dark p-6 cursor-pointer bg-am-blue group">
					<summary class="font-bold text-am-dark text-lg flex justify-between items-center">
						<span>Can I remove my signature?</span>
						<span class="group-open:rotate-45 transition-transform text-2xl leading-none" aria-hidden="true">+</span>
					</summary>
					<p class="font-bold text-am-dark mt-4">
						Yes. Email us at hello@publiccode.us and we'll remove your signature promptly.
					</p>
				</details>

				<details class="border-4 border-am-dark p-6 cursor-pointer bg-am-blue group">
					<summary class="font-bold text-am-dark text-lg flex justify-between items-center">
						<span>I'm not a U.S. citizen. Can I sign?</span>
						<span class="group-open:rotate-45 transition-transform text-2xl leading-none" aria-hidden="true">+</span>
					</summary>
					<p class="font-bold text-am-dark mt-4">
						We appreciate your support, but for ballot qualification purposes, we can only count signatures from registered voters. If you're a resident, register to vote and sign!
					</p>
				</details>

				<details class="border-4 border-am-dark p-6 cursor-pointer bg-am-blue group">
					<summary class="font-bold text-am-dark text-lg flex justify-between items-center">
						<span>What states are you targeting?</span>
						<span class="group-open:rotate-45 transition-transform text-2xl leading-none" aria-hidden="true">+</span>
					</summary>
					<p class="font-bold text-am-dark mt-4">
						We're starting with states that allow ballot initiatives and have lower signature requirements. We'll announce our state strategy soon. Every signature counts regardless of location.
					</p>
				</details>

				<details class="border-4 border-am-dark p-6 cursor-pointer bg-am-blue group">
					<summary class="font-bold text-am-dark text-lg flex justify-between items-center">
						<span>When is the ballot measure vote?</span>
						<span class="group-open:rotate-45 transition-transform text-2xl leading-none" aria-hidden="true">+</span>
					</summary>
					<p class="font-bold text-am-dark mt-4">
						Once we gather enough signatures, we'll qualify for the ballot in our target states. Most likely in 2026 or 2028 general elections. We'll keep you updated every step of the way.
					</p>
				</details>
			</div>
		</div>
	</section>

	{/* CTA */}
	<section class="bg-am-dark text-am-light border-b-4 border-am-dark py-16">
		<div class="max-w-4xl mx-auto px-4 text-center">
			<h2 class="text-3xl md:text-4xl font-bold mb-6">Questions?</h2>
			<a href="/about" class="btn-am btn-am-red inline-block">
				Learn More About Us
			</a>
		</div>
	</section>
</Layout>

<script>
	import confetti from 'canvas-confetti';
	(window as any).confetti = confetti;
</script>

<style>
	details summary::-webkit-details-marker {
		display: none;
	}
</style>
