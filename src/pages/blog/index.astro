---
import Layout from '../../layouts/main.astro';
import { NewsletterSignup } from '../../components/NewsletterSignup';

// Simple blog post metadata
const posts = [
  {
    slug: 'welcome-to-public-code-us',
    title: 'Welcome to Public Code US',
    description: 'Why we\'re fighting for public code, and why you should care',
    date: '2026-03-16',
    author: 'The Public Code US Team',
    readTime: '5 min read',
    featuredImage: '/feature-welcome.png',
    featuredImageAlt: 'The $640 million duplication problem visualized'
  },
  {
    slug: 'contact-your-representative',
    title: 'We Made It Easy to Contact Your Senator or Representative',
    description: 'You shouldn\'t need a lobbyist to talk to your elected officials. Here\'s how Public Code US puts direct democracy back in your hands.',
    date: '2026-03-27',
    author: 'The Public Code US Team',
    readTime: '4 min read',
    featuredImage: '/feature-contact-rep.png',
    featuredImageAlt: 'Four steps to contact your representative directly'
  }
];

// Sort by date, newest first
const sortedPosts = posts.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<Layout
  title="Blog - Public Code US Campaign Updates"
  description="Latest news, updates, and stories from the Public Code US campaign"
  currentPage="/blog"
>
  {/* Hero */}
  <section class="bg-am-light-blue text-am-light border-b-4 border-am-dark py-20">
    <div class="max-w-4xl mx-auto px-4">
      <h1 class="text-5xl md:text-6xl font-bold mb-6">Campaign Blog</h1>
      <p class="text-lg font-bold">
        Stories, updates, and insights from the Public Code US movement.
      </p>
    </div>
  </section>

  {/* Blog Posts */}
  <section class="bg-am-light border-b-4 border-am-dark py-20">
    <div class="max-w-4xl mx-auto px-4">
      <div class="space-y-8">
        {sortedPosts.map((post) => (
          <article>
            <a
              href={`/blog/${post.slug}`}
              class="border-4 border-am-dark block hover:shadow-am-lg hover:border-am-red transition-all group"
            >
              {post.featuredImage && (
                <img
                  src={post.featuredImage}
                  alt={post.featuredImageAlt}
                  class="w-full block border-b-4 border-am-dark"
                  loading="lazy"
                />
              )}
              <div class="p-8">
                <p class="text-sm font-bold uppercase tracking-widest text-am-dark mb-2">
                  {new Date(post.date).toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric'
                  })} • {post.readTime} • By {post.author}
                </p>
                <h2 class="text-3xl font-bold text-am-dark mb-3 group-hover:text-am-red transition-colors">
                  {post.title}
                </h2>
                <p class="font-bold text-am-dark text-lg mb-4">{post.description}</p>
                <span class="btn-am btn-am-primary inline-block">Read More →</span>
              </div>
            </a>
          </article>
        ))}
      </div>

      {sortedPosts.length === 0 && (
        <div class="text-center py-12">
          <p class="text-xl font-bold text-am-dark">Coming soon!</p>
          <p class="font-bold text-gray-600">Subscribe to stay updated.</p>
        </div>
      )}
    </div>
  </section>

  {/* Newsletter CTA */}
  <section class="bg-am-blue border-b-4 border-am-dark py-20">
    <div class="max-w-4xl mx-auto px-4">
      <NewsletterSignup
        client:load
        variant="card"
        source="blog"
      />
    </div>
  </section>

  {/* Latest Post Featured */}
  {sortedPosts.length > 0 && (
    <section class="bg-am-white border-b-4 border-am-dark py-20">
      <div class="max-w-4xl mx-auto px-4">
        <h2 class="text-3xl font-bold text-am-dark mb-8">Latest Update</h2>
        <a href={`/blog/${sortedPosts[0].slug}`} class="border-4 border-am-dark block hover:shadow-am-lg hover:border-am-red transition-all group">
          {sortedPosts[0].featuredImage && (
            <img
              src={sortedPosts[0].featuredImage}
              alt={sortedPosts[0].featuredImageAlt}
              class="w-full block border-b-4 border-am-dark"
              loading="lazy"
            />
          )}
          <div class="p-8 bg-am-light">
            <h3 class="text-2xl font-bold text-am-dark mb-4 group-hover:text-am-red transition-colors">
              {sortedPosts[0].title}
            </h3>
            <p class="font-bold text-am-dark mb-6">{sortedPosts[0].description}</p>
            <span class="btn-am btn-am-primary inline-block">Read Full Post →</span>
          </div>
        </a>
      </div>
    </section>
  )}
</Layout>
