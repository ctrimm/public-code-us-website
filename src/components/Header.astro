---
interface Props {
  currentPage?: string;
}

const { currentPage = '' } = Astro.props;

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Learn', href: '/learn' },
  { label: 'Campaign', href: '/campaign' },
  { label: 'Blog', href: '/blog' },
  { label: 'Organize', href: '/organize' },
  { label: 'Sign Petition', href: '/sign', highlight: true },
  { label: 'Resources', href: '/resources' },
  { label: 'About', href: '/about' },
];
---

<header class="border-b-4 border-nb-dark bg-nb-cyan sticky top-0 z-50">
  <nav class="max-w-7xl mx-auto px-4 py-4 flex items-center justify-between">
    {/* Logo */}
    <a href="/" class="text-2xl md:text-3xl font-black uppercase italic text-nb-dark no-underline">
      PUBLIC<br />CODE US
    </a>

    {/* Desktop Navigation */}
    <div class="hidden md:flex gap-1">
      {navItems.map((item) => (
        <a
          href={item.href}
          class={`px-4 py-2 border-2 border-nb-dark uppercase font-black text-sm tracking-widest transition-all no-underline ${
            item.highlight
              ? 'bg-nb-pink text-nb-light shadow-nb hover:shadow-nb-lg'
              : 'bg-nb-light text-nb-dark hover:shadow-nb'
          } ${currentPage === item.href ? 'bg-nb-purple text-nb-light' : ''}`}
        >
          {item.label}
        </a>
      ))}
    </div>

    {/* Mobile Menu Button */}
    <button id="mobile-menu-btn" class="md:hidden border-2 border-nb-dark p-2 bg-nb-light hover:shadow-nb">
      <span class="text-nb-dark font-black">MENU</span>
    </button>
  </nav>

  {/* Mobile Navigation */}
  <div id="mobile-menu" class="hidden md:hidden border-t-4 border-nb-dark bg-nb-light">
    {navItems.map((item) => (
      <a
        href={item.href}
        class={`block px-4 py-3 border-b-2 border-nb-dark uppercase font-black text-sm tracking-widest no-underline ${
          item.highlight
            ? 'bg-nb-pink text-nb-light'
            : 'bg-nb-light text-nb-dark hover:bg-nb-cyan'
        } ${currentPage === item.href ? 'bg-nb-purple text-nb-light' : ''}`}
      >
        {item.label}
      </a>
    ))}
  </div>
</header>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  if (mobileMenuBtn && mobileMenu) {
    mobileMenuBtn.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });

    // Close menu when a link is clicked
    const links = mobileMenu.querySelectorAll('a');
    links.forEach((link) => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
      });
    });
  }
</script>
