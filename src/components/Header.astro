---
interface Props {
  currentPage?: string;
}

const { currentPage = '' } = Astro.props;

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Learn', href: '/learn' },
  { label: 'Campaign', href: '/campaign' },
  { label: 'Blog', href: '/blog' },
  { label: 'Organize', href: '/organize' },
  { label: 'Sign Petition', href: '/sign', highlight: true }
];
---

<header class="border-b-4 border-nb-dark bg-nb-cyan sticky top-0 z-50">
  <nav class="max-w-7xl mx-auto px-4 py-4 flex items-center justify-between" aria-label="Main navigation">
    {/* Logo */}
    <a href="/" class="text-2xl md:text-3xl font-black uppercase italic text-nb-dark no-underline" aria-label="Public Code US - Home">
      PUBLIC<br />CODE US
    </a>

    {/* Desktop Navigation */}
    <div class="hidden md:flex gap-1" role="list">
      {navItems.map((item) => (
        <a
          href={item.href}
          role="listitem"
          aria-current={currentPage === item.href ? 'page' : undefined}
          class={`px-4 py-2 border-2 border-nb-dark uppercase font-black text-sm tracking-widest transition-all no-underline focus-visible:outline-3 focus-visible:outline-nb-dark focus-visible:outline-offset-2 ${
            item.highlight
              ? 'bg-nb-pink text-nb-dark shadow-nb hover:shadow-nb-lg'
              : 'bg-nb-light text-nb-dark hover:shadow-nb'
          } ${currentPage === item.href ? 'bg-nb-purple text-nb-dark' : ''}`}
        >
          {item.label}
        </a>
      ))}
    </div>

    {/* Mobile Menu Button */}
    <button
      id="mobile-menu-btn"
      class="md:hidden border-2 border-nb-dark p-2 bg-nb-light hover:shadow-nb focus-visible:outline-3 focus-visible:outline-nb-dark focus-visible:outline-offset-2"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Open navigation menu"
    >
      <span class="text-nb-dark font-black" aria-hidden="true">MENU</span>
    </button>
  </nav>

  {/* Mobile Navigation */}
  <nav id="mobile-menu" class="hidden md:hidden border-t-4 border-nb-dark bg-nb-light" aria-label="Mobile navigation">
    {navItems.map((item) => (
      <a
        href={item.href}
        aria-current={currentPage === item.href ? 'page' : undefined}
        class={`block px-4 py-3 border-b-2 border-nb-dark uppercase font-black text-sm tracking-widest no-underline focus-visible:outline-3 focus-visible:outline-nb-dark focus-visible:outline-offset-[-3px] ${
          item.highlight
            ? 'bg-nb-pink text-nb-dark'
            : 'bg-nb-light text-nb-dark hover:bg-nb-cyan'
        } ${currentPage === item.href ? 'bg-nb-purple text-nb-dark' : ''}`}
      >
        {item.label}
      </a>
    ))}
  </nav>
</header>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  if (mobileMenuBtn && mobileMenu) {
    mobileMenuBtn.addEventListener('click', () => {
      const isExpanded = mobileMenuBtn.getAttribute('aria-expanded') === 'true';
      mobileMenuBtn.setAttribute('aria-expanded', String(!isExpanded));
      mobileMenuBtn.setAttribute('aria-label', isExpanded ? 'Open navigation menu' : 'Close navigation menu');
      mobileMenu.classList.toggle('hidden');
    });

    // Close menu when a link is clicked
    const links = mobileMenu.querySelectorAll('a');
    links.forEach((link) => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
        mobileMenuBtn.setAttribute('aria-expanded', 'false');
        mobileMenuBtn.setAttribute('aria-label', 'Open navigation menu');
      });
    });

    // Close menu on Escape key and return focus to trigger
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !mobileMenu.classList.contains('hidden')) {
        mobileMenu.classList.add('hidden');
        mobileMenuBtn.setAttribute('aria-expanded', 'false');
        mobileMenuBtn.setAttribute('aria-label', 'Open navigation menu');
        mobileMenuBtn.focus();
      }
    });
  }
</script>
