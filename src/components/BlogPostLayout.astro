---
import Layout from '../layouts/main.astro';
import { ShareButtons } from './ShareButtons';

export interface Props {
  title: string;
  description: string;
  date: string;
  author?: string;
  image?: string;
  readTime?: string;
}

const { title, description, date, author = 'Public Code US Team', image, readTime } = Astro.props;
const url = Astro.url.href;
---

<Layout
  title={`${title} - Public Code US Blog`}
  description={description}
  image={image}
  currentPage="/blog"
>
  <article>
    {/* Hero Section */}
    <section class="bg-nb-purple text-nb-light border-b-4 border-nb-dark py-20">
      <div class="max-w-3xl mx-auto px-4">
        <div class="flex items-center gap-4 mb-4 font-bold text-sm">
          <span>{new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
          {readTime && <span>•</span>}
          {readTime && <span>{readTime}</span>}
          {author && <span>•</span>}
          {author && <span>By {author}</span>}
        </div>
        <h1 class="text-5xl md:text-6xl font-black uppercase italic mb-6">{title}</h1>
        <p class="text-lg font-bold">{description}</p>
      </div>
    </section>

    {/* Content */}
    <section class="bg-nb-light border-b-4 border-nb-dark py-20">
      <div class="max-w-3xl mx-auto px-4">
        <div class="prose prose-lg max-w-none font-bold text-nb-dark">
          <slot />
        </div>
      </div>
    </section>

    {/* Share Section */}
    <section class="bg-nb-cyan border-b-4 border-nb-dark py-20">
      <div class="max-w-3xl mx-auto px-4">
        <h2 class="text-3xl font-black uppercase italic text-nb-dark mb-6">Share This Post</h2>
        <ShareButtons
          client:load
          url={url}
          title={title}
          description={description}
        />
      </div>
    </section>

    {/* CTA Section */}
    <section class="bg-nb-pink text-nb-light border-b-4 border-nb-dark py-16">
      <div class="max-w-3xl mx-auto px-4 text-center">
        <h2 class="text-3xl font-black uppercase italic mb-6">Ready to Take Action?</h2>
        <a href="/sign" class="btn-nb btn-nb-yellow inline-block">
          Sign the Petition
        </a>
      </div>
    </section>
  </article>

  <style>
    .prose {
      font-weight: 600;
      line-height: 1.8;
    }

    .prose h2 {
      font-size: 1.875rem;
      font-weight: 900;
      text-transform: uppercase;
      font-style: italic;
      margin-top: 2rem;
      margin-bottom: 1rem;
      color: #09090B;
    }

    .prose h3 {
      font-size: 1.5rem;
      font-weight: 900;
      text-transform: uppercase;
      font-style: italic;
      margin-top: 1.5rem;
      margin-bottom: 0.75rem;
      color: #09090B;
    }

    .prose p {
      margin-bottom: 1rem;
    }

    .prose ul, .prose ol {
      margin-bottom: 1rem;
      margin-left: 1.5rem;
    }

    .prose li {
      margin-bottom: 0.5rem;
    }

    .prose a {
      color: #FF4081;
      text-decoration: underline;
    }

    .prose a:hover {
      text-decoration: none;
    }

    .prose strong {
      font-weight: 900;
    }

    .prose blockquote {
      border-left: 4px solid #FF4081;
      padding-left: 1rem;
      font-style: italic;
      color: #6b7280;
      margin: 1rem 0;
    }
  </style>
</Layout>
