---
import Layout from '../layouts/main.astro';
import { ShareButtons } from './ShareButtons';

export interface Props {
  title?: string;
  description?: string;
  date?: string;
  author?: string;
  image?: string;
  featuredImage?: string;
  featuredImageAlt?: string;
  readTime?: string;
  frontmatter?: {
    title: string;
    description: string;
    date: string;
    author?: string;
    image?: string;
    featuredImage?: string;
    featuredImageAlt?: string;
    readTime?: string;
  };
}

// Get properties from either direct props or frontmatter object
const props = Astro.props as any;
const frontmatter = props.frontmatter || props;
const title = frontmatter.title || 'Untitled Post';
const description = frontmatter.description || '';
const date = frontmatter.date || new Date().toISOString();
const author = frontmatter.author || 'Public Code US Team';
const image = frontmatter.image;
const featuredImage = frontmatter.featuredImage;
const featuredImageAlt = frontmatter.featuredImageAlt || title;
const readTime = frontmatter.readTime;
const url = Astro.url.href;
---

<Layout
  title={`${title} - Public Code US Blog`}
  description={description}
  image={image}
  currentPage="/blog"
  type="article"
  date={date}
  author={author}
>
  <article>
    {/* Hero Section */}
    <section class="bg-am-light-blue text-am-light border-b-4 border-am-dark py-20">
      <div class="max-w-3xl mx-auto px-4">
        <div class="flex items-center gap-4 mb-4 font-bold text-sm">
          <span>{new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
          {readTime && <span>•</span>}
          {readTime && <span>{readTime}</span>}
          {author && <span>•</span>}
          {author && <span>By {author}</span>}
        </div>
        <h1 class="text-5xl md:text-6xl font-bold mb-6">{title}</h1>
        <p class="text-lg font-bold">{description}</p>
      </div>
    </section>

    {/* Featured Image */}
    {featuredImage && (
      <div class="border-b-4 border-am-dark">
        <img
          src={featuredImage}
          alt={featuredImageAlt}
          class="w-full block"
          loading="eager"
        />
      </div>
    )}

    {/* Content */}
    <section class="bg-am-light border-b-4 border-am-dark py-20">
      <div class="max-w-3xl mx-auto px-4">
        <div class="prose prose-lg max-w-none font-bold text-am-dark">
          <slot />
        </div>
      </div>
    </section>

    {/* Share Section */}
    <section class="bg-am-blue border-b-4 border-am-dark py-20">
      <div class="max-w-3xl mx-auto px-4">
        <h2 class="text-3xl font-bold text-am-dark mb-6">Share This Post</h2>
        <ShareButtons
          client:load
          url={url}
          title={title}
          description={description}
        />
      </div>
    </section>

    {/* CTA Section */}
    <section class="bg-am-red text-am-light border-b-4 border-am-dark py-16">
      <div class="max-w-3xl mx-auto px-4 text-center">
        <h2 class="text-3xl font-bold mb-6">Ready to Take Action?</h2>
        <a href="/sign" class="btn-am btn-am-white inline-block">
          Sign the Petition
        </a>
      </div>
    </section>
  </article>

  <style is:global>
    .prose {
      font-weight: 400;
      line-height: 1.8;
      color: #0A1128;
    }

    .prose h1 {
      font-size: 3rem;
      font-weight: 800;
      margin-top: 2.5rem;
      margin-bottom: 2rem;
      color: #0A1128;
      letter-spacing: -0.01em;
      line-height: 1.2;
    }

    .prose h2 {
      font-size: 1.875rem;
      font-weight: 800;
      margin-top: 2.5rem;
      margin-bottom: 1.5rem;
      color: #0A1128;
      letter-spacing: -0.01em;
    }

    .prose h3 {
      font-size: 1.5rem;
      font-weight: 800;
      margin-top: 2rem;
      margin-bottom: 1rem;
      color: #0A1128;
      letter-spacing: -0.01em;
    }

    .prose p {
      margin-bottom: 2rem;
    }

    .prose ul, .prose ol {
      margin-bottom: 2rem;
      margin-left: 1.5rem;
    }

    .prose li {
      margin-bottom: 0.5rem;
    }

    .prose a {
      color: #0033A0;
      text-decoration: underline;
      font-weight: 600;
    }

    .prose a:hover {
      text-decoration: none;
      color: #002880;
    }

    .prose strong {
      font-weight: 700;
    }

    .prose blockquote {
      border-left: 4px solid #0033A0;
      padding-left: 1.5rem;
      font-style: italic;
      color: #4B5563;
      margin: 2rem 0;
    }
  </style>
</Layout>
