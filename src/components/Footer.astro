---
const currentYear = new Date().getFullYear();
---

<footer class="border-t-4 border-nb-dark bg-nb-dark text-nb-light">
  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
      {/* Brand */}
      <div class="col-span-1 md:col-span-2">
        <h3 class="text-2xl font-black uppercase italic mb-4">Public Code US</h3>
        <p class="font-bold text-sm mb-4">
          A campaign demanding transparent, publicly owned software in government.
        </p>
        <p class="text-xs font-bold">
          Funded by citizens. Powered by open source advocates across America.
        </p>
      </div>

      {/* Quick Links */}
      <nav aria-label="Footer navigation">
        <h4 class="text-sm font-black uppercase tracking-wider mb-4">Navigation</h4>
        <ul class="space-y-2 text-sm font-bold">
          <li><a href="/" class="hover:underline focus-visible:outline-2 focus-visible:outline-nb-light focus-visible:outline-offset-2">Home</a></li>
          <li><a href="/learn" class="hover:underline focus-visible:outline-2 focus-visible:outline-nb-light focus-visible:outline-offset-2">Learn</a></li>
          <li><a href="/sign" class="hover:underline focus-visible:outline-2 focus-visible:outline-nb-light focus-visible:outline-offset-2">Sign Petition</a></li>
          <li><a href="/resources" class="hover:underline focus-visible:outline-2 focus-visible:outline-nb-light focus-visible:outline-offset-2">Resources</a></li>
          <li><a href="/about" class="hover:underline focus-visible:outline-2 focus-visible:outline-nb-light focus-visible:outline-offset-2">About</a></li>
        </ul>
      </nav>

      {/* Legal */}
      <nav aria-label="Legal links">
        <h4 class="text-sm font-black uppercase tracking-wider mb-4">Legal</h4>
        <ul class="space-y-2 text-sm font-bold">
          <li><a href="/privacy" class="hover:underline focus-visible:outline-2 focus-visible:outline-nb-light focus-visible:outline-offset-2">Privacy Policy</a></li>
          <li><a href="/terms" class="hover:underline focus-visible:outline-2 focus-visible:outline-nb-light focus-visible:outline-offset-2">Terms of Service</a></li>
          <li><a href="mailto:hello@publiccodeus.org" class="hover:underline focus-visible:outline-2 focus-visible:outline-nb-light focus-visible:outline-offset-2">Contact</a></li>
        </ul>
      </nav>
    </div>

    {/* Divider */}
    <div class="border-t-2 border-nb-light my-8" role="separator"></div>

    {/* Bottom */}
    <div class="flex flex-col md:flex-row justify-between items-center text-xs font-bold">
      <p>&copy; {currentYear} Public Code US. All rights reserved.</p>
      <div class="flex gap-4 mt-4 md:mt-0">
        <a href="https://threads.net/@publiccodeus" target="_blank" rel="noopener noreferrer" class="hover:underline focus-visible:outline-2 focus-visible:outline-nb-light focus-visible:outline-offset-2">
          Threads<span class="sr-only"> (opens in new tab)</span>
        </a>
        <a href="https://github.com/publiccodeus" target="_blank" rel="noopener noreferrer" class="hover:underline focus-visible:outline-2 focus-visible:outline-nb-light focus-visible:outline-offset-2">
          GitHub<span class="sr-only"> (opens in new tab)</span>
        </a>
        <a href="https://www.fsfe.org/activities/publiccode/" target="_blank" rel="noopener noreferrer" class="hover:underline focus-visible:outline-2 focus-visible:outline-nb-light focus-visible:outline-offset-2">
          FSFE<span class="sr-only"> (opens in new tab)</span>
        </a>
      </div>
    </div>
  </div>
</footer>
